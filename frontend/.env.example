# Datos de la cuenta bancaria del taller mostrados en Facturacion
# (panel de Transferencia/QR). Copiar a .env.local y completar con
# los datos reales; .env.local no se sube al repositorio.
REACT_APP_BANCO_NOMBRE=Banco Ejemplo
REACT_APP_BANCO_TIPO_CUENTA=Ahorros
REACT_APP_BANCO_NUMERO_CUENTA=0000000-000-000
REACT_APP_BANCO_TITULAR=Nombre Apellido
REACT_APP_BANCO_NIT=00000000

# Client ID de PayPal (sandbox) usado por el boton de pago del cliente.
# No es secreto, pero copiar a .env.local con el valor real del taller.
REACT_APP_PAYPAL_CLIENT_ID=sb-xxxxxxxxxxxx
